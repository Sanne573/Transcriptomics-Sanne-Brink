  BiocManager::install("GO.db")
}
if (!requireNamespace("enrichplot", quietly = TRUE)) {
  BiocManager::install("enrichplot")
}
library(clusterProfiler)
library(org.Hs.eg.db)
library(GO.db)
library(enrichplot)
  # Data inladen 
All <- read.table("Resultaten.txt", header = TRUE)

  # Subset maken met padj < 0.05*
library(dplyr)
DEGs <- All %>%
  filter(padj < 0.05)
DEGs <- rownames(DEGs)

 # GO Enrichment analyse
enrichFrame <- enrichGO(DEGs,
                        OrgDb = org.Hs.eg.db,
                        keyType = "SYMBOL",
                        ont = "ALL",
                        pAdjustMethod = "BH",
                        pvalueCutoff = 0.05,
                        qvalueCutoff = 0.2)
  # Visualisatie GO Enrichment analyse
    # Dotplot top 10
png("GO_dotplot1.png", width = 1200, height = 900, res = 150)
dotplot(enrichFrame,
        x = "GeneRatio",
        color = "p.adjust",
        title = "Top 10 van GO Enrichment",
        showCategory = 10,
        label_format = 60)
dev.off()

